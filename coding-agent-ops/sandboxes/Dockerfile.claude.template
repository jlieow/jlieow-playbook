# Minimal Claude Code sandbox
FROM node:20-bookworm

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# --- Add project-specific dependencies below (e.g., Go, Terraform, Python, Rust) ---


# --- End project-specific dependencies ---

# Create non-root user (Claude Code blocks --dangerously-skip-permissions as root)
RUN useradd -m -s /bin/bash agent \
    && mkdir -p /home/agent/.claude \
    && chown -R agent:agent /home/agent

# Set working directory
WORKDIR /workspace

# Switch to non-root user
USER agent

# Default command
ENTRYPOINT ["claude"]
